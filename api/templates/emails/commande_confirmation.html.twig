<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Confirmation de commande</title>
</head>
<body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background:#F5F0E8; margin:0; padding:40px 20px;">
    <table role="presentation" style="max-width:600px; margin:0 auto; background:white; border-radius:4px; padding:40px;">
        <tr>
            <td style="text-align:center; padding-bottom:24px; border-bottom:1px solid #eee;">
                <h1 style="font-family:Georgia, serif; color:#1A1208; font-size:28px; margin:0;">
                    Vite <span style="color:#D4521A;">&</span> Gourmand
                </h1>
            </td>
        </tr>

        <tr>
            <td style="padding:32px 0 16px;">
                <h2 style="font-family:Georgia, serif; color:#1A1208; font-size:22px; margin:0 0 8px;">Merci {{ prenom }} !</h2>
                <p style="color:#555; line-height:1.6; font-size:15px; margin:0;">
                    Votre commande <strong>{{ commande.numeroCommande }}</strong> a bien été enregistrée.
                    Julie ou José va la valider dans les meilleurs délais et vous recevrez une confirmation.
                </p>
            </td>
        </tr>

        <tr>
            <td style="padding:16px 0;">
                <div style="background:#FAFAF9; border-left:4px solid #D4521A; padding:20px; border-radius:2px;">
                    <p style="color:#888; font-size:12px; text-transform:uppercase; font-weight:600; letter-spacing:0.05em; margin:0 0 12px;">
                        Récapitulatif de votre commande
                    </p>

                    <p style="color:#1A1208; font-size:16px; font-weight:600; margin:0 0 4px;">{{ commande.menu.titre }}</p>
                    <p style="color:#666; font-size:14px; margin:0 0 20px;">
                        Pour {{ commande.nombrePersonnes }} personnes
                    </p>

                    <table role="presentation" style="width:100%; font-size:14px; color:#555;">
                        <tr>
                            <td style="padding:4px 0;">Date de prestation</td>
                            <td style="padding:4px 0; text-align:right; font-weight:500;">{{ commande.datePrestation|date('d/m/Y') }}</td>
                        </tr>
                        <tr>
                            <td style="padding:4px 0;">Heure de livraison</td>
                            <td style="padding:4px 0; text-align:right; font-weight:500;">{{ commande.heureLivraison|date('H:i') }}</td>
                        </tr>
                        <tr>
                            <td style="padding:4px 0; vertical-align:top;">Adresse</td>
                            <td style="padding:4px 0; text-align:right; font-weight:500;">{{ commande.adresseLivraison }}<br>{{ commande.villeLivraison }}</td>
                        </tr>
                    </table>

                    <table role="presentation" style="width:100%; font-size:14px; color:#555; margin-top:16px; border-top:1px solid #eee; padding-top:12px;">
                        <tr>
                            <td style="padding:4px 0;">Prix du menu</td>
                            <td style="padding:4px 0; text-align:right;">{{ commande.prixMenu|number_format(2, ',', ' ') }} €</td>
                        </tr>
                        {% if commande.reduction > 0 %}
                        <tr>
                            <td style="padding:4px 0; color:#4A7C59;">Réduction 10%</td>
                            <td style="padding:4px 0; text-align:right; color:#4A7C59;">−{{ commande.reduction|number_format(2, ',', ' ') }} €</td>
                        </tr>
                        {% endif %}
                        <tr>
                            <td style="padding:4px 0;">Frais de livraison</td>
                            <td style="padding:4px 0; text-align:right;">
                                {% if commande.prixLivraison == 0 %}
                                    <span style="color:#4A7C59;">Offerts (Bordeaux)</span>
                                {% else %}
                                    {{ commande.prixLivraison|number_format(2, ',', ' ') }} €
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <td style="padding:12px 0 4px; border-top:1px solid #ddd; font-weight:700; font-size:15px; color:#1A1208;">Total</td>
                            <td style="padding:12px 0 4px; border-top:1px solid #ddd; text-align:right; font-weight:700; font-size:16px; color:#1A1208;">
                                {{ commande.prixTotal|number_format(2, ',', ' ') }} €
                            </td>
                        </tr>
                    </table>
                </div>
            </td>
        </tr>

        {% if commande.menu.conditions %}
        <tr>
            <td style="padding:16px 0;">
                <div style="background:#FFF7ED; border:1px solid #FFEDD5; padding:16px; border-radius:2px;">
                    <p style="color:#C2410C; font-size:12px; text-transform:uppercase; font-weight:600; margin:0 0 6px;">
                        ⚠ Conditions particulières
                    </p>
                    <p style="color:#555; font-size:13px; margin:0; line-height:1.5;">{{ commande.menu.conditions }}</p>
                </div>
            </td>
        </tr>
        {% endif %}

        <tr>
            <td style="padding:24px 0; text-align:center; color:#888; font-size:13px; line-height:1.6;">
                Vous pouvez modifier ou annuler votre commande tant qu'elle est en statut "En attente".<br>
                Une fois validée par notre équipe, contactez-nous pour toute demande.
            </td>
        </tr>

        <tr>
            <td style="padding-top:24px; border-top:1px solid #eee; text-align:center; color:#aaa; font-size:12px;">
                Vite & Gourmand — Traiteur artisanal à Bordeaux
            </td>
        </tr>
    </table>
</body>
</html>
